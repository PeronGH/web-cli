{
  "name": "web-cli",
  "version": "0.1.0",
  "description": "A CLI to search and fetch the web",
  "type": "module",
  "bin": {
    "web": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target node --outdir dist",
    "prepublishOnly": "bun run build",
    "format": "biome format --write .",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "latest",
    "citty": "^0.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
