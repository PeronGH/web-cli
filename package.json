{
  "name": "web-cli",
  "version": "0.1.0",
  "description": "A CLI to search and fetch the web",
  "type": "module",
  "bin": {
    "web": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target node --outdir dist --minify",
    "prepublishOnly": "bun run build",
    "format": "biome format --write .",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "latest",
    "citty": "^0.2.2",
    "defuddle": "^0.18.1",
    "linkedom": "^0.18.12",
    "mathml-to-latex": "^1.8.0",
    "turndown": "^7.2.4",
    "undici": "^8.4.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
